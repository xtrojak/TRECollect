{
  "forms": [
    {
      "id": "aml_contaminated_site",
      "name": "AML Contaminated Site Assessment",
      "section": "Site Assessment",
      "description": "Abandoned Mine Land contaminated site identification and assessment",
      "mandatory": true,
      "fields": [
        {
          "id": "aml_site_id",
          "label": "AML Site Identifier",
          "type": "text",
          "required": true
        },
        {
          "id": "contamination_gps",
          "label": "Contamination Site GPS Coordinates",
          "type": "gps",
          "required": true
        },
        {
          "id": "mine_type",
          "label": "Mine Type",
          "type": "select",
          "options": ["Coal", "Metal", "Non-metal", "Uranium", "Abandoned Processing", "Waste Pile", "Other"],
          "required": true
        },
        {
          "id": "contamination_category",
          "label": "Contamination Category",
          "type": "multiselect",
          "options": ["Acid Mine Drainage", "Heavy Metals", "Radionuclides", "Organic Contaminants", "Sediment", "Water", "Soil", "Air"],
          "required": true
        },
        {
          "id": "site_condition",
          "label": "Site Condition",
          "type": "select",
          "options": ["Active", "Inactive", "Abandoned", "Reclaimed", "Partially Reclaimed", "Unknown"],
          "required": true
        },
        {
          "id": "site_photographs",
          "label": "Site Assessment Photographs",
          "type": "photo",
          "required": false
        },
        {
          "id": "site_assessment_notes",
          "label": "Site Assessment Notes",
          "type": "textarea",
          "required": false
        }
      ]
    },
    {
      "id": "aml_environmental_sampling",
      "name": "AML Environmental Sampling Protocol",
      "section": "Environmental Sampling",
      "description": "AML environmental media sampling protocol and collection",
      "mandatory": true,
      "fields": [
        {
          "id": "sampling_media",
          "label": "Sampling Media",
          "type": "select",
          "options": ["Surface Water", "Groundwater", "Soil", "Sediment", "Air", "Biological", "Waste Material", "Other"],
          "required": true
        },
        {
          "id": "sampling_matrix",
          "label": "Sampling Matrix Details",
          "type": "table",
          "rows": ["Sample 1", "Sample 2", "Sample 3", "Sample 4", "Sample 5"],
          "columns": ["Sample ID", "GPS Location", "Depth/Height", "Volume/Weight", "Preservation"],
          "inputType": "text",
          "required": true
        },
        {
          "id": "sampling_protocol",
          "label": "Sampling Protocol",
          "type": "select",
          "options": ["EPA Method", "ASTM Standard", "State Protocol", "Site-Specific", "Other"],
          "required": true
        },
        {
          "id": "collection_date",
          "label": "Collection Date",
          "type": "date",
          "required": true
        },
        {
          "id": "collection_time",
          "label": "Collection Time",
          "type": "time",
          "required": true
        },
        {
          "id": "environmental_conditions",
          "label": "Environmental Conditions",
          "type": "section"
        },
        {
          "id": "air_temperature",
          "label": "Air Temperature (°C)",
          "type": "text",
          "inputType": "number",
          "required": false
        },
        {
          "id": "wind_speed",
          "label": "Wind Speed (km/h)",
          "type": "text",
          "inputType": "number",
          "required": false
        },
        {
          "id": "precipitation",
          "label": "Precipitation (mm)",
          "type": "text",
          "inputType": "number",
          "required": false
        },
        {
          "id": "sampling_photo",
          "label": "Sampling Process Photo",
          "type": "photo",
          "required": false
        }
      ]
    },
    {
      "id": "aml_contaminant_analysis",
      "name": "AML Contaminant Analysis",
      "section": "Contaminant Analysis",
      "description": "AML contaminant analysis and regulatory compliance assessment",
      "mandatory": false,
      "fields": [
        {
          "id": "contaminant_analysis",
          "label": "Contaminant Analysis Results",
          "type": "dynamic",
          "required": false,
          "instance_name": "Analysis Sample",
          "subFields": [
            {
              "id": "analysis_sample_id",
              "label": "Analysis Sample ID",
              "type": "barcode",
              "required": true
            },
            {
              "id": "analysis_date",
              "label": "Analysis Date",
              "type": "date",
              "required": true
            },
            {
              "id": "contaminant_analytes",
              "label": "Contaminant Analytes",
              "type": "multiselect",
              "options": ["Arsenic (As)", "Lead (Pb)", "Mercury (Hg)", "Cadmium (Cd)", "Chromium (Cr)", "Uranium (U)", "Radium (Ra)", "Selenium (Se)", "Copper (Cu)", "Zinc (Zn)", "PAHs", "PCBs", "Other"],
              "required": false
            },
            {
              "id": "concentration_value",
              "label": "Concentration Value",
              "type": "text",
              "inputType": "number",
              "required": false
            },
            {
              "id": "concentration_units",
              "label": "Concentration Units",
              "type": "select",
              "options": ["mg/kg", "mg/L", "µg/kg", "µg/L", "ppm", "ppb", "pCi/g", "Bq/kg"],
              "required": false
            },
            {
              "id": "regulatory_limit",
              "label": "Regulatory Limit",
              "type": "text",
              "inputType": "number",
              "required": false
            },
            {
              "id": "compliance_status",
              "label": "Compliance Status",
              "type": "select",
              "options": ["Below Limit", "At Limit", "Exceeds Limit", "Significantly Exceeds", "Unknown"],
              "required": false
            },
            {
              "id": "remediation_priority",
              "label": "Remediation Priority",
              "type": "select",
              "options": ["Low", "Medium", "High", "Critical", "Not Applicable"],
              "required": false
            },
            {
              "id": "analysis_notes",
              "label": "Analysis Notes",
              "type": "textarea",
              "required": false
            }
          ]
        }
      ]
    }
  ]
}
