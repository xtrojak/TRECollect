{
  "forms": [
    {
      "id": "lsi_soil_site_location",
      "name": "LSI Soil Site Location",
      "section": "Location & Site Setup",
      "description": "Comprehensive soil sampling site location and characterization",
      "mandatory": true,
      "fields": [
        {
          "id": "site_identifier",
          "label": "LSI Site Identifier",
          "type": "text",
          "required": true
        },
        {
          "id": "soil_site_gps",
          "label": "Soil Sampling GPS Coordinates",
          "type": "gps",
          "required": true
        },
        {
          "id": "land_use_type",
          "label": "Land Use Type",
          "type": "select",
          "options": ["Agricultural", "Forest", "Grassland", "Urban", "Wetland", "Disturbed", "Other"],
          "required": true
        },
        {
          "id": "soil_classification",
          "label": "Soil Classification",
          "type": "select",
          "options": ["Entisol", "Inceptisol", "Mollisol", "Alfisol", "Ultisol", "Spodosol", "Histosol", "Other"],
          "required": true
        },
        {
          "id": "soil_texture",
          "label": "Soil Texture",
          "type": "multiselect",
          "options": ["Sand", "Silt", "Clay", "Loam", "Sandy Loam", "Clay Loam", "Silty Loam"],
          "required": true
        },
        {
          "id": "site_photographs",
          "label": "Site Photographs",
          "type": "photo",
          "required": false
        },
        {
          "id": "site_notes",
          "label": "Site Characterization Notes",
          "type": "textarea",
          "required": false
        }
      ]
    },
    {
      "id": "lsi_soil_core_collection",
      "name": "LSI Soil Core Collection",
      "section": "Soil Core Sampling",
      "description": "Detailed soil core collection protocol and procedures",
      "mandatory": true,
      "fields": [
        {
          "id": "core_collection_protocol",
          "label": "Core Collection Protocol",
          "type": "select",
          "options": ["Standard Core", "Composite Core", "Depth Profile", "Horizon-Specific", "Other"],
          "required": true
        },
        {
          "id": "core_depth_layers",
          "label": "Core Depth Layers (cm)",
          "type": "table",
          "rows": ["0-10", "10-20", "20-30", "30-50", "50-100"],
          "columns": ["Depth", "Volume Collected (mL)", "Preservation Method"],
          "inputType": "text",
          "required": true
        },
        {
          "id": "core_diameter",
          "label": "Core Diameter (mm)",
          "type": "text",
          "inputType": "number",
          "required": true
        },
        {
          "id": "collection_date_time",
          "label": "Collection Date & Time",
          "type": "date",
          "required": true
        },
        {
          "id": "collection_time_detail",
          "label": "Collection Time",
          "type": "time",
          "required": true
        },
        {
          "id": "soil_temperature",
          "label": "Soil Temperature at Collection (°C)",
          "type": "text",
          "inputType": "number",
          "required": false
        },
        {
          "id": "core_collection_photo",
          "label": "Core Collection Process Photo",
          "type": "photo",
          "required": false
        },
        {
          "id": "soil_texture_visual",
          "label": "Soil Texture (Visual Selection)",
          "type": "select_image",
          "required": false,
          "options": [
            {
              "value": "tap",
              "image": "images/tap.png",
              "label": "Tap"
            },
            {
              "value": "adven",
              "image": "images/adven.png",
              "label": "Adven"
            },
            {
              "value": "heart",
              "image": "images/heart.png",
              "label": "Heart"
            },
            {
              "value": "flat",
              "image": "images/flat.png",
              "label": "Flat"
            }
          ]
        },
        {
          "id": "vegetation_types",
          "label": "Vegetation Types Present",
          "type": "multiselect_image",
          "required": false,
          "options": [
            {
              "value": "tap",
              "image": "images/tap.png",
              "label": "Tap"
            },
            {
              "value": "adven",
              "image": "images/adven.png",
              "label": "Adven"
            },
            {
              "value": "heart",
              "image": "images/heart.png",
              "label": "Heart"
            },
            {
              "value": "flat",
              "image": "images/flat.png",
              "label": "Flat"
            }
          ]
        }
      ]
    },
    {
      "id": "lsi_soil_lab_analysis",
      "name": "LSI Soil Laboratory Analysis",
      "section": "Laboratory Analysis",
      "description": "Soil laboratory analysis results and measurements",
      "mandatory": false,
      "fields": [
        {
          "id": "soil_chemistry_analysis",
          "label": "Soil Chemistry Analysis",
          "type": "dynamic",
          "required": false,
          "instance_name": "Analysis Batch",
          "subFields": [
            {
              "id": "batch_id",
              "label": "Analysis Batch ID",
              "type": "barcode",
              "required": true
            },
            {
              "id": "analysis_date",
              "label": "Analysis Date",
              "type": "date",
              "required": true
            },
            {
              "id": "ph_measurement",
              "label": "pH Measurement",
              "type": "text",
              "inputType": "number",
              "required": false
            },
            {
              "id": "organic_carbon",
              "label": "Organic Carbon (%)",
              "type": "text",
              "inputType": "number",
              "required": false
            },
            {
              "id": "total_nitrogen",
              "label": "Total Nitrogen (mg/kg)",
              "type": "text",
              "inputType": "number",
              "required": false
            },
            {
              "id": "phosphorus",
              "label": "Phosphorus (mg/kg)",
              "type": "text",
              "inputType": "number",
              "required": false
            },
            {
              "id": "potassium",
              "label": "Potassium (mg/kg)",
              "type": "text",
              "inputType": "number",
              "required": false
            },
            {
              "id": "cation_exchange",
              "label": "Cation Exchange Capacity (cmol/kg)",
              "type": "text",
              "inputType": "number",
              "required": false
            },
            {
              "id": "analysis_notes",
              "label": "Analysis Notes",
              "type": "textarea",
              "required": false
            }
          ]
        }
      ]
    }
  ]
}
