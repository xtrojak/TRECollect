{
  "forms": [
    {
      "id": "lsi_shoreline_habitat",
      "name": "LSI Shoreline Habitat Assessment",
      "section": "Habitat & Location",
      "description": "Shoreline habitat characterization and location details",
      "mandatory": true,
      "fields": [
        {
          "id": "shoreline_site_id",
          "label": "Shoreline Site Identifier",
          "type": "text",
          "required": true
        },
        {
          "id": "shoreline_gps",
          "label": "Shoreline GPS Coordinates",
          "type": "gps",
          "required": true
        },
        {
          "id": "shoreline_type",
          "label": "Shoreline Type",
          "type": "select",
          "options": ["Rocky", "Sandy Beach", "Muddy", "Mixed Substrate", "Artificial", "Marsh", "Mangrove", "Other"],
          "required": true
        },
        {
          "id": "habitat_zone",
          "label": "Habitat Zone",
          "type": "multiselect",
          "options": ["Supralittoral", "Littoral", "Sublittoral", "Intertidal", "Subtidal"],
          "required": true
        },
        {
          "id": "tidal_regime",
          "label": "Tidal Regime",
          "type": "select",
          "options": ["Microtidal (<2m)", "Mesotidal (2-4m)", "Macrotidal (>4m)", "Non-tidal"],
          "required": false
        },
        {
          "id": "habitat_photographs",
          "label": "Habitat Photographs",
          "type": "photo",
          "required": false
        },
        {
          "id": "habitat_notes",
          "label": "Habitat Characterization Notes",
          "type": "textarea",
          "required": false
        }
      ]
    },
    {
      "id": "lsi_shoreline_quadrat",
      "name": "LSI Shoreline Quadrat Sampling",
      "section": "Quadrat Sampling",
      "description": "Shoreline quadrat and transect sampling protocol",
      "mandatory": true,
      "fields": [
        {
          "id": "sampling_design",
          "label": "Sampling Design",
          "type": "select",
          "options": ["Random Quadrats", "Systematic Transect", "Stratified Random", "Haphazard", "Other"],
          "required": true
        },
        {
          "id": "quadrat_transect_data",
          "label": "Quadrat/Transect Data",
          "type": "table",
          "rows": ["Q1", "Q2", "Q3", "Q4", "Q5", "Q6", "Q7", "Q8", "Q9", "Q10"],
          "columns": ["GPS Location", "Zone", "Substrate Type", "Coverage (%)"],
          "inputType": "text",
          "required": true
        },
        {
          "id": "quadrat_size",
          "label": "Quadrat Size (m²)",
          "type": "text",
          "inputType": "number",
          "required": true
        },
        {
          "id": "sampling_date",
          "label": "Sampling Date",
          "type": "date",
          "required": true
        },
        {
          "id": "sampling_time",
          "label": "Sampling Time",
          "type": "time",
          "required": true
        },
        {
          "id": "tide_level_at_sampling",
          "label": "Tide Level at Sampling",
          "type": "select",
          "options": ["High Tide", "Mid Tide", "Low Tide", "Ebbing", "Flooding", "Unknown"],
          "required": false
        },
        {
          "id": "weather_conditions",
          "label": "Weather Conditions",
          "type": "select",
          "options": ["Clear", "Partly Cloudy", "Overcast", "Rain", "Windy", "Stormy"],
          "required": false
        },
        {
          "id": "quadrat_sampling_photo",
          "label": "Quadrat Sampling Photo",
          "type": "photo",
          "required": false
        }
      ]
    },
    {
      "id": "lsi_shoreline_biodiversity",
      "name": "LSI Shoreline Biodiversity Assessment",
      "section": "Biodiversity Assessment",
      "description": "Shoreline biodiversity and ecological assessment",
      "mandatory": false,
      "fields": [
        {
          "id": "biodiversity_observations",
          "label": "Biodiversity Observations",
          "type": "dynamic",
          "required": false,
          "instance_name": "Observation",
          "subFields": [
            {
              "id": "observation_id",
              "label": "Observation ID",
              "type": "barcode",
              "required": true
            },
            {
              "id": "taxonomic_group",
              "label": "Taxonomic Group",
              "type": "multiselect",
              "options": ["Algae", "Seagrass", "Mollusks", "Crustaceans", "Polychaetes", "Echinoderms", "Fish", "Birds", "Other"],
              "required": false
            },
            {
              "id": "abundance",
              "label": "Abundance",
              "type": "select",
              "options": ["None", "Rare", "Occasional", "Common", "Abundant", "Dominant"],
              "required": false
            },
            {
              "id": "ecological_indicator",
              "label": "Ecological Indicator Status",
              "type": "select",
              "options": ["Native", "Non-native", "Invasive", "Endangered", "Unknown"],
              "required": false
            },
            {
              "id": "contamination_indicators",
              "label": "Contamination Indicators",
              "type": "multiselect",
          "options": ["No Signs", "Discoloration", "Odor", "Foam", "Oil Sheen", "Algal Bloom", "Dead Organisms"],
              "required": false
            },
            {
              "id": "biodiversity_notes",
              "label": "Biodiversity Notes",
              "type": "textarea",
              "required": false
            }
          ]
        }
      ]
    }
  ]
}
