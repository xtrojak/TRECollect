      "fields": [
        {
          "id": "site_name",
          "label": "Site Name",
          "type": "text",
          "required": true
        },
        {
          "id": "site_code",
          "label": "Site Code",
          "type": "text",
          "required": false
        },
        {
          "id": "location_gps",
          "label": "GPS Location",
          "type": "gps",
          "required": true
        },
        {
          "id": "site_photo",
          "label": "Site Photo",
          "type": "photo",
          "required": false
        },
        {
          "id": "site_barcode",
          "label": "Site Barcode/QR Code",
          "type": "barcode",
          "required": false
        },
        {
          "id": "site_description",
          "label": "Site Description",
          "type": "textarea",
          "required": false
        }
      ]
    },
    {
