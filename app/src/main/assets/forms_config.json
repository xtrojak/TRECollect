        {
          "id": "sample_containers",
          "label": "Sample Container Types",
          "type": "multiselect",
          "options": ["Glass Bottle", "Plastic Bottle", "Vial", "Bag", "Other"],
          "required": false
        },
        {
          "id": "collection_date",
          "label": "Collection Date",
          "type": "date",
          "required": true
        },
        {
          "id": "collection_time",
          "label": "Collection Time",
          "type": "time",
          "required": false
        },
        {
          "id": "collection_gps",
          "label": "Collection Point GPS",
          "type": "gps",
          "required": false
        },
        {
          "id": "sample_barcodes",
          "label": "Sample Container Barcodes",
          "type": "barcode",
          "required": false
        },
        {
          "id": "collection_photo",
          "label": "Collection Photo",
          "type": "photo",
          "required": false
        },
        {
          "id": "collection_notes",
          "label": "Collection Notes",
          "type": "textarea",
          "required": false
        }
      ]
    },
    {
      "id": "test_form_1",
      "name": "Test Form 1",
      "section": "Testing",
      "description": "Test form with various field types",
      "mandatory": false,
      "fields": [
        {
          "id": "test_table",
          "label": "Sample Measurements Table",
          "type": "table",
          "rows": ["Sample 1", "Sample 2", "Sample 3"],
          "columns": ["Temperature (°C)", "pH", "Conductivity (µS/cm)"],
          "inputType": "number",
          "required": false
        },
        {
          "id": "test_table_text",
          "label": "Observations Table",
          "type": "table",
          "rows": ["Morning", "Afternoon", "Evening"],
          "columns": ["Weather", "Notes"],
          "inputType": "text",
          "required": false
        }
      ]
    },
    {
      "id": "sample_measurements",
